{
  "properties": {
    "protocols": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "grpc",
          "grpcs",
          "http",
          "https"
        ]
      },
      "description": "A set of strings representing HTTP protocols.",
      "default": [
        "grpc",
        "grpcs",
        "http",
        "https"
      ]
    },
    "config": {
      "type": "object",
      "properties": {
        "injection_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "java_exception",
              "js",
              "sql",
              "ssi",
              "xpath_abbreviated",
              "xpath_extended"
            ]
          },
          "description": "The type of injections to check for.",
          "default": [
            "sql"
          ]
        },
        "locations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "body",
              "headers",
              "path",
              "path_and_query",
              "query"
            ]
          },
          "description": "The locations to check for injection.",
          "default": [
            "path_and_query"
          ]
        },
        "custom_injections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "A unique name for this injection."
              },
              "regex": {
                "type": "string",
                "description": "The regex to match against."
              }
            },
            "required": [
              "name",
              "regex"
            ]
          },
          "description": "Custom regexes to check for."
        },
        "enforcement_mode": {
          "type": "string",
          "enum": [
            "block",
            "log_only"
          ],
          "description": "Enforcement mode of the security policy.",
          "default": "block"
        },
        "error_status_code": {
          "type": "integer",
          "maximum": 499,
          "minimum": 400,
          "description": "The response status code when validation fails.",
          "default": 400
        },
        "error_message": {
          "type": "string",
          "description": "The response message when validation fails",
          "default": "Bad Request"
        }
      }
    },
    "route": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "description": "If set, the plugin will only activate when receiving requests via the specified route. Leave unset for the plugin to activate regardless of the route being used."
    },
    "service": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "description": "If set, the plugin will only activate when receiving requests via one of the routes belonging to the specified Service. Leave unset for the plugin to activate regardless of the Service being matched."
    }
  }
}